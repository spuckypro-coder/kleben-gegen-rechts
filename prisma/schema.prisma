generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("admin")
  lastSeen  DateTime?
  createdAt DateTime  @default(now())
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  filename    String
  category    String   @default("allgemein")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Product {
  id          String         @id @default(cuid())
  name        String
  description String?
  price       Float
  filename    String
  stock       Int            @default(0)
  artist      String         @default("Kleben Gegen Rechts")
  active      Boolean        @default(true)
  featured    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  orderItems  OrderItem[]
  images      ProductImage[]
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  position  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id         String      @id @default(cuid())
  email      String
  name       String
  address    String
  total      Float
  status     String      @default("pending")
  createdAt  DateTime    @default(now())
  items      OrderItem[]
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model PublicUser {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String
  password   String
  newsletter Boolean   @default(true)
  createdAt  DateTime  @default(now())
  comments   Comment[]
}

model Comment {
  id         String      @id @default(cuid())
  postSlug   String
  userId     String?
  authorName String
  content    String
  createdAt  DateTime    @default(now())
  user       PublicUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  coverImage  String?
  category    String   @default("antifaschismus")
  sources     String?
  published     Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
